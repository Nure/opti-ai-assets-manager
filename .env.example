PORT=8080
NODE_ENV=production
APP_DATA_DIR=/app/data
PUBLIC_BASE_URL=http://localhost:8080

# Optional AI page-scan review and metadata enrichment
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional CMP DAM API integration. If omitted, the app runs in safe simulation mode.
CMP_API_BASE_URL=
CMP_BEARER_TOKEN=
CMP_ORG_ID=
CMP_DEFAULT_FOLDER_ID=

# Safety
MAX_DOWNLOAD_MB=250

# CMP DAM asset download using OAuth client credentials
CMP_CLIENT_ID=
CMP_CLIENT_SECRET=
CMP_TOKEN_URL=https://accounts.cmp.optimizely.com/o/oauth2/v1/token

# Host-mounted project directory for downloaded asset folders and download XLSX reports.
APP_OUTPUT_DIR=/host-app
